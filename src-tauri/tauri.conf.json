{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "clientcontroller",
    "version":  "0.1.3",
    "identifier":  "de.followflow.clientcontroller",
    "build":  {
                  "beforeDevCommand":  "npm run prepare:workflow-runtime && npm run dev",
                  "devUrl":  "http://localhost:1420",
                  "beforeBuildCommand":  "npm run install:workflow-runtime && npm run build",
                  "frontendDist":  "../dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "clientcontroller",
                                    "width":  800,
                                    "height":  600
                                }
                            ],
                "security":  {
                                 "csp":  null
                             }
            },
    "plugins":  {
                     "updater":  {
                                     "pubkey":  "",
                                     "endpoints":  []
                                 }
                 },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "createUpdaterArtifacts":  true,
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.icns",
                                "icons/icon.ico"
                            ],
                   "resources":  [
                                     "resources/platform-tools/**/*",
                                     "resources/drivers/**/*",
                                     "resources/workflow-runtime/**/*"
                                 ]
               }
}
